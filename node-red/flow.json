        "max": 80,
        "colors": ["#00b500", "#e6c729", "#ca3838"],
        "seg1": "45",
        "seg2": "60",
        "x": 910,
        "y": 140,
        "wires": []
    },
    {
        "id": "ui_gauge_weight",
        "type": "ui_gauge",
        "z": "tab_battery_monitor",
        "name": "Weight Gauge",
        "group": "grp_overview",
        "order": 4,
        "width": 4,
        "height": 4,
        "gtype": "gage",
        "title": "Battery Weight",
        "label": "kg",
        "format": "{{value}}",
        "min": 0,
        "max": 20,
        "colors": ["#00b500", "#e6c729", "#ca3838"],
        "seg1": "12",
