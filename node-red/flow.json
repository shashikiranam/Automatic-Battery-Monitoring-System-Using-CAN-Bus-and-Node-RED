        "gtype": "gage",
        "title": "Battery Voltage",
        "label": "V",
        "format": "{{value}}",
        "min": 0,
        "max": 15,
        "colors": ["#ca3838", "#e6c729", "#00b500"],
        "seg1": "10.5",
        "seg2": "12.6",
        "x": 900,
        "y": 40,
        "wires": []
    },
    {
        "id": "ui_gauge_current",
        "type": "ui_gauge",
        "z": "tab_battery_monitor",
