    {
        "id": "ui_text_battery_status",
        "type": "ui_text",
        "z": "tab_battery_monitor",
        "group": "grp_status",
        "order": 1,
        "width": 4,
        "height": 2,
        "name": "Battery Status Text",
        "label": "Battery Status",
        "format": "{{msg.payload.batteryStatus}}",
        "layout": "row-spread",
        "x": 930,
        "y": 290,
        "wires": []
    },
    {
        "id": "ui_led_can_status",
        "type": "ui_led",
        "z": "tab_battery_monitor",
        "group": "grp_status",
        "order": 2,
        "width": 4,
        "height": 2,
        "name": "CAN Bus Status LED",
        "label": "CAN Bus OK",
        "labelPlacement": "left",
        "labelAlignment": "left",
        "shape": "circle",
        "colorForValue": [
            { "color": "#00b500", "value": "false", "valueType": "bool" },
            { "color": "#ca3838", "value": "true", "valueType": "bool" }
