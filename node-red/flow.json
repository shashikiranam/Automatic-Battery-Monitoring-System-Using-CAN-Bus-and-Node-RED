        "group": "grp_trends",
        "order": 2,
        "width": 6,
        "height": 4,
        "label": "Current (A) - Last 10 min",
        "chartType": "line",
        "legend": "false",
        "xformat": "HH:mm:ss",
        "interpolate": "linear",
        "nodata": "Waiting for data...",
        "removeOlder": 10,
        "removeOlderPoints": "",
        "removeOlderUnit": "60",
        "cutout": 0,
        "colors": ["#ff7f0e"],
        "x": 1130,
        "y": 90,
        "wires": [[]]
    },
    {
        "id": "ui_chart_temperature",
        "type": "ui_chart",
        "z": "tab_battery_monitor",
        "name": "Temperature Trend",
        "group": "grp_trends",
        "order": 3,
