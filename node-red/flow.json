        "width": 4,
        "height": 4,
        "gtype": "gage",
        "title": "Battery Current",
        "label": "A",
        "format": "{{value}}",
        "min": 0,
        "max": 10,
        "colors": ["#00b500", "#e6c729", "#ca3838"],
        "seg1": "5",
        "seg2": "8",
        "x": 900,
        "y": 90,
        "wires": []
    },
    {
        "id": "ui_gauge_temperature",
        "type": "ui_gauge",
        "z": "tab_battery_monitor",
        "name": "Temperature Gauge",
        "group": "grp_overview",
