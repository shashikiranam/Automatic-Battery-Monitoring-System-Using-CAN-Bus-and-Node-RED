[
    {
        "id": "tab_battery_monitor",
        "type": "tab",
        "label": "Battery Monitoring System",
        "disabled": false,
        "info": "Automatic Battery Monitoring System - CAN Bus ingestion, decoding, and dashboard.\n\nRequires:\n  - node-red-contrib-socketcan (or equivalent CAN-to-MQTT/Serial gateway)\n  - node-red-dashboard\n\nThis flow assumes a SocketCAN interface (e.g. can0) is available on the\nNode-RED host, bridged to the physical CAN bus via a USB-CAN adapter or\na Linux SBC with native CAN hardware. See docs/NODE_RED_ARCHITECTURE.md.",
        "env": []
    },
    {
        "id": "can_in_node",
        "type": "socketcan-in",
        "z": "tab_battery_monitor",
        "name": "CAN0 Interface (500kbps)",
        "interface": "can0",
        "x": 150,
        "y": 80,
        "wires": [
            [
                "fn_route_by_id"
            ]
        ]
    },
    {
        "id": "fn_route_by_id",
        "type": "switch",
        "z": "tab_battery_monitor",
        "name": "Route by CAN ID",
        "property": "id",
        "propertyType": "msg",
        "rules": [
            { "t": "eq", "v": "0x100", "vt": "str" },
            { "t": "eq", "v": "0x101", "vt": "str" },
            { "t": "eq", "v": "0x102", "vt": "str" },
            { "t": "eq", "v": "0x103", "vt": "str" },
            { "t": "eq", "v": "0x104", "vt": "str" },
            { "t": "eq", "v": "0x105", "vt": "str" }
        ],
        "checkall": "true",
        "repair": false,
        "outputs": 6,
        "x": 380,
        "y": 80,
        "wires": [
            ["fn_decode_voltage"],
            ["fn_decode_current"],
            ["fn_decode_temperature"],
            ["fn_decode_weight"],
            ["fn_decode_power"],
            ["fn_decode_system_status"]
        ]
    },
    {
        "id": "fn_decode_voltage",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Decode 0x100 Voltage",
        "func": "// CAN Frame 0x100 - Battery Voltage\n// Bytes [0-1]: int16 big-endian, scale factor 100 -> Volts\nconst data = msg.payload; // array of bytes\nconst raw = (data[0] << 8) | data[1];\nconst signedRaw = raw > 32767 ? raw - 65536 : raw;\nconst voltage = signedRaw / 100.0;\n\nmsg.payload = voltage;\nmsg.topic = \"battery/voltage\";\nreturn msg;",
        "outputs": 1,
        "x": 630,
        "y": 40,
        "wires": [
            [
                "ui_gauge_voltage",
                "ui_chart_voltage",
                "fn_merge_state"
            ]
        ]
    },
    {
        "id": "fn_decode_current",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Decode 0x101 Current",
        "func": "// CAN Frame 0x101 - Battery Current\n// Bytes [0-1]: int16 big-endian, scale factor 100 -> Amps (signed)\nconst data = msg.payload;\nconst raw = (data[0] << 8) | data[1];\nconst signedRaw = raw > 32767 ? raw - 65536 : raw;\nconst current = signedRaw / 100.0;\n\nmsg.payload = current;\nmsg.topic = \"battery/current\";\nreturn msg;",
        "outputs": 1,
        "x": 630,
        "y": 90,
        "wires": [
            [
                "ui_gauge_current",
                "ui_chart_current",
                "fn_merge_state"
            ]
        ]
    },
    {
        "id": "fn_decode_temperature",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Decode 0x102 Temperature",
        "func": "// CAN Frame 0x102 - Battery Temperature\n// Bytes [0-1]: int16 big-endian, scale factor 100 -> Degrees C (signed)\nconst data = msg.payload;\nconst raw = (data[0] << 8) | data[1];\nconst signedRaw = raw > 32767 ? raw - 65536 : raw;\nconst temperature = signedRaw / 100.0;\n\nmsg.payload = temperature;\nmsg.topic = \"battery/temperature\";\nreturn msg;",
        "outputs": 1,
        "x": 640,
        "y": 140,
        "wires": [
            [
                "ui_gauge_temperature",
                "ui_chart_temperature",
                "fn_merge_state"
            ]
        ]
    },
    {
        "id": "fn_decode_weight",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Decode 0x103 Weight",
        "func": "// CAN Frame 0x103 - Battery Weight\n// Bytes [0-1]: int16 big-endian, scale factor 1000 -> Kilograms\nconst data = msg.payload;\nconst raw = (data[0] << 8) | data[1];\nconst signedRaw = raw > 32767 ? raw - 65536 : raw;\nconst weight = signedRaw / 1000.0;\n\nmsg.payload = weight;\nmsg.topic = \"battery/weight\";\nreturn msg;",
        "outputs": 1,
        "x": 620,
        "y": 190,
        "wires": [
            [
                "ui_gauge_weight",
                "fn_merge_state"
            ]
        ]
    },
    {
        "id": "fn_decode_power",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Decode 0x104 Power",
        "func": "// CAN Frame 0x104 - Battery Power\n// Bytes [0-1]: int16 big-endian, scale factor 100 -> Watts\nconst data = msg.payload;\nconst raw = (data[0] << 8) | data[1];\nconst signedRaw = raw > 32767 ? raw - 65536 : raw;\nconst power = signedRaw / 100.0;\n\nmsg.payload = power;\nmsg.topic = \"battery/power\";\nreturn msg;",
        "outputs": 1,
        "x": 620,
        "y": 240,
        "wires": [
            [
                "ui_gauge_power",
                "ui_chart_power",
                "fn_merge_state"
            ]
        ]
    },
    {
        "id": "fn_decode_system_status",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Decode 0x105 System Status",
        "func": "// CAN Frame 0x105 - System Status\n// Byte 0: battery status enum (0=GOOD,1=WARNING,2=CRITICAL,3=FAULT)\n// Byte 1: CAN bus error flag (0/1)\n// Byte 2: sensors OK flag (0/1)\n// Byte 3: alert flags bitmask (bit0=overV,bit1=underV,bit2=overI,bit3=overT)\nconst data = msg.payload;\nconst statusMap = [\"GOOD\", \"WARNING\", \"CRITICAL\", \"FAULT\"];\nconst statusCode = data[0];\nconst canError = data[1] === 1;\nconst sensorsOk = data[2] === 1;\nconst alertFlags = data[3];\n\nconst alerts = [];\nif (alertFlags & 0x01) alerts.push(\"Overvoltage\");\nif (alertFlags & 0x02) alerts.push(\"Undervoltage\");\nif (alertFlags & 0x04) alerts.push(\"Overcurrent\");\nif (alertFlags & 0x08) alerts.push(\"Overtemperature\");\n\nmsg.payload = {\n    batteryStatus: statusMap[statusCode] || \"UNKNOWN\",\n    canError: canError,\n    sensorsOk: sensorsOk,\n    alerts: alerts\n};\nmsg.topic = \"battery/system_status\";\nreturn msg;",
        "outputs": 1,
        "x": 650,
        "y": 300,
        "wires": [
            [
                "ui_text_battery_status",
                "ui_led_can_status",
                "fn_alert_notification",
                "fn_merge_state"
            ]
        ]
    },
    {
        "id": "fn_merge_state",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Merge Latest State",
        "func": "// Maintain a merged snapshot of the most recent value for every topic\n// so the numeric display / table widgets always show a complete row.\nconst state = flow.get('batteryState') || {};\nstate[msg.topic] = msg.payload;\nstate.lastUpdated = new Date().toISOString();\nflow.set('batteryState', state);\n\nmsg.payload = state;\nmsg.topic = \"battery/state_snapshot\";\nreturn msg;",
        "outputs": 1,
        "x": 900,
        "y": 160,
        "wires": [
            [
                "ui_table_snapshot"
            ]
        ]
    },
    {
        "id": "fn_alert_notification",
        "type": "function",
        "z": "tab_battery_monitor",
        "name": "Build Alert Notification",
        "func": "if (msg.payload.batteryStatus === \"CRITICAL\" || msg.payload.alerts.length > 0) {\n    msg.payload = {\n        text: `Battery status: ${msg.payload.batteryStatus}. Alerts: ${msg.payload.alerts.join(', ') || 'None'}`,\n        displayTime: 6\n    };\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 900,
        "y": 340,
        "wires": [
            [
                "ui_toast_alert"
            ]
        ]
    },
    {
        "id": "ui_gauge_voltage",
        "type": "ui_gauge",
        "z": "tab_battery_monitor",
        "name": "Voltage Gauge",
