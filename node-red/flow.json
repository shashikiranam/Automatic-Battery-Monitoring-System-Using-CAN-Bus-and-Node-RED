        "id": "ui_toast_alert",
        "type": "ui_toast",
        "z": "tab_battery_monitor",
        "position": "top right",
        "displayTime": "6",
        "highlight": "#ca3838",
        "sendall": true,
        "outdir": "outdir",
        "name": "Battery Alert Toast",
        "x": 1150,
        "y": 340,
        "wires": []
    },
    {
        "id": "ui_table_snapshot",
        "type": "ui_template",
        "z": "tab_battery_monitor",
        "group": "grp_overview",
        "name": "Live Telemetry Table",
        "order": 6,
        "width": 8,
        "height": 6,
        "format": "<table style=\"width:100%; font-size:14px;\">\n  <tr><td><b>Voltage</b></td><td>{{msg.payload['battery/voltage']}} V</td></tr>\n  <tr><td><b>Current</b></td><td>{{msg.payload['battery/current']}} A</td></tr>\n  <tr><td><b>Temperature</b></td><td>{{msg.payload['battery/temperature']}} \u00b0C</td></tr>\n  <tr><td><b>Weight</b></td><td>{{msg.payload['battery/weight']}} kg</td></tr>\n  <tr><td><b>Power</b></td><td>{{msg.payload['battery/power']}} W</td></tr>\n  <tr><td><b>Last Updated</b></td><td>{{msg.payload.lastUpdated}}</td></tr>\n</table>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "x": 1150,
        "y": 190,
        "wires": [[]]
    },
